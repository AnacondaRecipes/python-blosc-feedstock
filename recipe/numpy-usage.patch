From f42189394e38fb25a42082ed111cc7a358225766 Mon Sep 17 00:00:00 2001
From: Ivan Iziumov <iiziumov@anaconda.com>
Date: Thu, 11 Sep 2025 15:44:21 +0200
Subject: [PATCH] Fix deprecated numpy.fromstring usage in compress_ptr

---
 blosc/toplevel.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/blosc/toplevel.py b/blosc/toplevel.py
index 4d2d413..3ef2327 100644
--- a/blosc/toplevel.py
+++ b/blosc/toplevel.py
@@ -513,7 +513,7 @@
     >>> c = blosc.compress_ptr(np_array.__array_interface__['data'][0], \
         items, np_array.dtype.itemsize)
     >>> d = blosc.decompress(c)
-    >>> np_ans = numpy.fromstring(d, dtype=np_array.dtype)
+    >>> np_ans = numpy.frombuffer(d, dtype=np_array.dtype)
     >>> bool((np_array == np_ans).all())
     True
